# Copy from Writers Room `.env.local` if you like — same variable names.
ANTHROPIC_API_KEY=sk-ant-...

# Spotify Web API (client credentials) — Song → books via track links only
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Optional ISO country for artist top-tracks (default US)
# SPOTIFY_MARKET=US

# API protection — set a strong random string, send as: Authorization: Bearer <value>
# Generate with: openssl rand -base64 32
# Leave unset for local dev (check is skipped when not configured)
# Both vars must be set to the same value: server uses API_SECRET, client uses NEXT_PUBLIC_API_SECRET
API_SECRET=
NEXT_PUBLIC_API_SECRET=

# Spotify playlist export (PKCE OAuth — no secret needed)
# Set to the same value as SPOTIFY_CLIENT_ID.
# Must be marked NEXT_PUBLIC so the browser can initiate the auth redirect.
# Also register http://localhost:3001/spotify-callback and your production URL
# as a Redirect URI in your Spotify app dashboard.
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
