# Copy from Writers Room `.env.local` if you like — same variable names.
ANTHROPIC_API_KEY=sk-ant-...

# Spotify Web API (client credentials) — Song → books via track links only
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Optional ISO country for artist top-tracks (default US)
# SPOTIFY_MARKET=US

# API protection — set a strong random string, send as: Authorization: Bearer <value>
# Generate with: openssl rand -base64 32
# Leave unset for local dev (check is skipped when not configured)
API_SECRET=
